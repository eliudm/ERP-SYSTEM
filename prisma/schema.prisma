generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH & USERS
// ============================================

enum Role {
  ADMIN
  ACCOUNTANT
  SALES_USER
  INVENTORY_MANAGER
  HR_MANAGER
  PROCUREMENT_OFFICER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  role         Role     @default(SALES_USER)
  posOnly      Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// ============================================
// ACCOUNTING
// ============================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  VOID
}

model Account {
  id            String      @id @default(uuid())
  code          String      @unique
  name          String
  type          AccountType
  parentId      String?
  parent        Account?    @relation("AccountTree", fields: [parentId], references: [id])
  children      Account[]   @relation("AccountTree")
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  journalLines  JournalLine[]
  bankAccounts  BankAccount[]
  taxRates      TaxRate[]
  budgetLines   BudgetLine[]

  @@map("accounts")
}

model JournalEntry {
  id          String        @id @default(uuid())
  reference   String        @unique
  description String?
  entryDate   DateTime
  currency    String        @default("KES")
  exchangeRate Decimal      @default(1) @db.Decimal(18, 6)
  status      JournalStatus @default(DRAFT)
  sourceType  String?       // e.g. "SALES_INVOICE", "PAYMENT"
  sourceId    String?       // ID of the source document
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       JournalLine[]

  @@map("journal_entries")
}

model CurrencyRate {
  id            String   @id @default(uuid())
  baseCurrency  String
  quoteCurrency String
  rate          Decimal  @db.Decimal(18, 6)
  rateDate      DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([baseCurrency, quoteCurrency, rateDate])
  @@index([baseCurrency, quoteCurrency, rateDate])
  @@map("currency_rates")
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0) @db.Decimal(18, 2)
  credit         Decimal      @default(0) @db.Decimal(18, 2)
  description        String?
  createdAt          DateTime            @default(now())
  bankStatementLines BankStatementLine[]

  @@map("journal_lines")
}

model AccountingPeriod {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("accounting_periods")
}

// ============================================
// SALES
// ============================================

enum InvoiceStatus {
  DRAFT
  APPROVED
  SENT
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
  CREDIT
}

model Customer {
  id           String         @id @default(uuid())
  name         String
  email        String?
  phone        String?
  address      String?
  taxPin       String?        // KRA PIN
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  invoices     SalesInvoice[]
  quotes       SalesQuote[]
  creditNotes  CreditNote[]
  recurringInvoiceTemplates RecurringInvoiceTemplate[]

  @@map("customers")
}

model SalesInvoice {
  id           String             @id @default(uuid())
  invoiceNo    String             @unique
  customerId   String
  customer     Customer           @relation(fields: [customerId], references: [id])
  branchId     String?
  branch       Branch?            @relation(fields: [branchId], references: [id])
  invoiceDate  DateTime
  dueDate      DateTime?
  status       InvoiceStatus      @default(DRAFT)
  subtotal     Decimal            @db.Decimal(18, 2)
  taxAmount    Decimal            @db.Decimal(18, 2)
  total        Decimal            @db.Decimal(18, 2)
  paymentMethod PaymentMethod?
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  items        SalesInvoiceItem[]
  mpesaTransactions MpesaTransaction[]
  etimsInvoice EtimsInvoice?
  quotes       SalesQuote[]
  creditNotes  CreditNote[]
  recurringRuns RecurringInvoiceRun[]
  notifications Notification[]

  @@map("sales_invoices")
}

enum MpesaTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model MpesaTransaction {
  id                String                 @id @default(uuid())
  invoiceId         String
  invoice           SalesInvoice           @relation(fields: [invoiceId], references: [id])
  phoneNumber       String
  amount            Decimal                @db.Decimal(18, 2)
  merchantRequestId String?
  checkoutRequestId String?                @unique
  resultCode        Int?
  resultDesc        String?
  receiptNumber     String?
  transactionDate   DateTime?
  status            MpesaTransactionStatus @default(PENDING)
  callbackPayload   Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([invoiceId, status])
  @@map("mpesa_transactions")
}

model SalesInvoiceItem {
  id          String       @id @default(uuid())
  invoiceId   String
  invoice     SalesInvoice @relation(fields: [invoiceId], references: [id])
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  description String?
  quantity    Decimal      @db.Decimal(18, 2)
  unitPrice   Decimal      @db.Decimal(18, 2)
  taxRate     Decimal      @db.Decimal(5, 2)
  taxAmount   Decimal      @db.Decimal(18, 2)
  lineTotal   Decimal      @db.Decimal(18, 2)
  createdAt   DateTime     @default(now())

  @@map("sales_invoice_items")
}

// ============================================
// INVENTORY
// ============================================

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

model Warehouse {
  id             String          @id @default(uuid())
  name           String
  code           String?         @unique
  branchId       String?
  branch         Branch?         @relation(fields: [branchId], references: [id])
  location       String?
  isActive       Boolean         @default(true)
  createdAt      DateTime          @default(now())
  stockMovements StockMovement[]
  stockCounts    StockCount[]
  serialNumbers  SerialNumber[]
  transfersFrom  StockTransfer[]   @relation("TransferFrom")
  transfersTo    StockTransfer[]   @relation("TransferTo")

  @@map("warehouses")
}

model Branch {
  id         String         @id @default(uuid())
  name       String
  code       String         @unique
  location   String?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  warehouses Warehouse[]
  invoices   SalesInvoice[]
  recurringInvoiceTemplates RecurringInvoiceTemplate[]

  @@map("branches")
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  color     String?   // hex color e.g. "#1677ff"
  icon      String?   // emoji e.g. "\uD83E\uDE91"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("product_categories")
}

model Product {
  id              String             @id @default(uuid())
  code            String             @unique
  barcode         String?            @unique
  name            String
  description     String?
  categoryId      String?
  category        ProductCategory?   @relation(fields: [categoryId], references: [id])
  unitPrice       Decimal            @db.Decimal(18, 2)
  taxRate         Decimal            @default(0.16) @db.Decimal(5, 2)
  stockQuantity   Decimal            @default(0) @db.Decimal(18, 2)
  reorderLevel    Decimal            @default(0) @db.Decimal(18, 2)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  stockMovements      StockMovement[]
  invoiceItems        SalesInvoiceItem[]
  procurementItems    ProcurementItem[]
  quoteItems          SalesQuoteItem[]
  creditNoteItems     CreditNoteItem[]
  priceListItems      PriceListItem[]
  lots                Lot[]
  serialNumbers       SerialNumber[]
  variants            ProductVariant[]
  landedCostItems     LandedCostItem[]
  stockCountLines     StockCountLine[]
  transferLines       StockTransferLine[]
  rfqItems            RFQItem[]
  vendorBillItems     VendorBillItem[]
  purchaseReturnItems PurchaseReturnItem[]
  recurringTemplateItems RecurringInvoiceTemplateItem[]
  reorderRules           ReorderRule[]
  bomProducts            BillOfMaterial[]   @relation("BOMProduct")
  bomComponents          BOMLine[]          @relation("BOMComponent")

  @@map("products")
}

model StockMovement {
  id            String       @id @default(uuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  warehouseId   String
  warehouse     Warehouse    @relation(fields: [warehouseId], references: [id])
  movementType  MovementType
  quantity      Decimal      @db.Decimal(18, 2)
  unitCost      Decimal?     @db.Decimal(18, 2)
  reference     String?
  notes         String?
  lotId         String?
  lot           Lot?         @relation(fields: [lotId], references: [id])
  createdAt     DateTime     @default(now())

  @@map("stock_movements")
}

// ============================================
// PROCUREMENT
// ============================================

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  RECEIVED
  VOID
}

model Supplier {
  id             String          @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  taxPin         String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders  PurchaseOrder[]
  rfqs            RequestForQuotation[]
  vendorBills     VendorBill[]
  purchaseReturns PurchaseReturn[]
  reorderRules    ReorderRule[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String               @id @default(uuid())
  orderNo     String               @unique
  supplierId  String
  supplier    Supplier             @relation(fields: [supplierId], references: [id])
  rfqId       String?              @unique
  rfq         RequestForQuotation? @relation(fields: [rfqId], references: [id])
  orderDate   DateTime
  status      PurchaseOrderStatus  @default(DRAFT)
  subtotal    Decimal              @db.Decimal(18, 2)
  taxAmount   Decimal              @db.Decimal(18, 2)
  total       Decimal              @db.Decimal(18, 2)
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  items           ProcurementItem[]
  landedCosts     LandedCost[]
  vendorBills     VendorBill[]
  purchaseReturns PurchaseReturn[]

  @@map("purchase_orders")
}

model ProcurementItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(18, 2)
  unitCost        Decimal       @db.Decimal(18, 2)
  taxRate         Decimal       @db.Decimal(5, 2)
  taxAmount       Decimal       @db.Decimal(18, 2)
  lineTotal       Decimal       @db.Decimal(18, 2)
  createdAt       DateTime      @default(now())

  @@map("procurement_items")
}

// ============================================
// ETIMS
// ============================================

enum EtimsStatus {
  PENDING
  SUBMITTED
  SUCCESS
  FAILED
}

model EtimsInvoice {
  id              String               @id @default(uuid())
  invoiceId       String               @unique
  invoice         SalesInvoice         @relation(fields: [invoiceId], references: [id])
  status          EtimsStatus          @default(PENDING)
  qrCode          String?
  etimsInvoiceNo  String?
  submittedAt     DateTime?
  responseData    Json?
  retryCount      Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  submissionLogs  EtimsSubmissionLog[]

  @@map("etims_invoices")
}

// ============================================
// HR
// ============================================

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

model Employee {
  id            String         @id @default(uuid())
  employeeNo    String         @unique
  firstName     String
  lastName      String
  email         String         @unique
  phone         String?
  department    String?
  position      String?
  salary        Decimal        @db.Decimal(18, 2)
  startDate     DateTime
  status        EmployeeStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  payrollLines       PayrollLine[]
  leaveRequests      LeaveRequest[]
  attendanceRecords  AttendanceRecord[]
  appraisals         Appraisal[]
  allowances         Allowance[]
  loanDeductions     LoanDeduction[]

  @@map("employees")
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
}

model Payroll {
  id          String        @id @default(uuid())
  month       Int
  year        Int
  status      PayrollStatus @default(DRAFT)
  totalGross  Decimal       @db.Decimal(18, 2)
  totalPaye   Decimal       @db.Decimal(18, 2)
  totalNhif   Decimal       @db.Decimal(18, 2)
  totalNssf   Decimal       @db.Decimal(18, 2)
  totalNet    Decimal       @db.Decimal(18, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       PayrollLine[]

  @@unique([month, year])
  @@map("payrolls")
}

model PayrollLine {
  id            String   @id @default(uuid())
  payrollId     String
  payroll       Payroll  @relation(fields: [payrollId], references: [id])
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  grossSalary   Decimal  @db.Decimal(18, 2)
  payeAmount    Decimal  @db.Decimal(18, 2)
  nhifAmount    Decimal  @db.Decimal(18, 2)
  nssfAmount             Decimal  @db.Decimal(18, 2)
  totalAllowances        Decimal  @default(0) @db.Decimal(18, 2)
  totalLoanDeductions    Decimal  @default(0) @db.Decimal(18, 2)
  netSalary              Decimal  @db.Decimal(18, 2)
  allowancesSnapshot     Json?
  loanDeductionsSnapshot Json?
  createdAt              DateTime @default(now())

  @@map("payroll_lines")
}

model LeaveRequest {
  id          String      @id @default(uuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  leaveType   LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("leave_requests")
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model SystemSetting {
  key                String   @id
  companyName        String
  companyLogo        String?  @db.Text
  companyPin         String?
  companyAddress     String?
  receiptSlogan      String?
  defaultCurrency    String   @default("KES")
  timezone           String   @default("Africa/Nairobi")
  defaultLanguage    String   @default("en-KE")
  emailNotifications Boolean  @default(true)
  autoApproveDrafts  Boolean  @default(false)
  showLowStockAlerts  Boolean  @default(true)
  lowStockThreshold   Int      @default(5)
  posReceiptBranding  Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("system_settings")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  tableName  String
  recordId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model EtimsSubmissionLog {
  id            String       @id @default(uuid())
  etimsId       String
  etimsInvoice  EtimsInvoice @relation(fields: [etimsId], references: [id])
  attempt       Int
  requestData   Json
  responseData  Json?
  status        String
  errorMessage  String?
  createdAt     DateTime     @default(now())

  @@map("etims_submission_logs")
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  PAYMENT_REMINDER
  APPROVAL_REQUIRED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  SYSTEM
}

model Notification {
  id         String           @id @default(uuid())
  type       NotificationType
  title      String
  message    String
  productId  String?
  invoiceId  String?
  invoice    SalesInvoice?    @relation(fields: [invoiceId], references: [id])
  recipientEmail String?
  sentViaEmail  Boolean        @default(false)
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@map("notifications")
}

// ============================================
// BANKING & RECONCILIATION
// ============================================

enum BankStatementStatus {
  DRAFT
  RECONCILED
}

model BankAccount {
  id            String          @id @default(uuid())
  name          String
  accountNumber String
  bankName      String
  currency      String          @default("KES")
  glAccountId   String?
  glAccount     Account?        @relation(fields: [glAccountId], references: [id])
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  statements    BankStatement[]

  @@map("bank_accounts")
}

model BankStatement {
  id             String              @id @default(uuid())
  bankAccountId  String
  bankAccount    BankAccount         @relation(fields: [bankAccountId], references: [id])
  statementDate  DateTime
  openingBalance Decimal             @db.Decimal(18, 2)
  closingBalance Decimal             @db.Decimal(18, 2)
  status         BankStatementStatus @default(DRAFT)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lines          BankStatementLine[]

  @@map("bank_statements")
}

model BankStatementLine {
  id                   String        @id @default(uuid())
  statementId          String
  statement            BankStatement @relation(fields: [statementId], references: [id])
  transactionDate      DateTime
  description          String
  paymentMethod        PaymentMethod?
  debit                Decimal       @default(0) @db.Decimal(18, 2)
  credit               Decimal       @default(0) @db.Decimal(18, 2)
  matchedJournalLineId String?
  matchedJournalLine   JournalLine?  @relation(fields: [matchedJournalLineId], references: [id])
  isMatched            Boolean       @default(false)
  createdAt            DateTime      @default(now())

  @@map("bank_statement_lines")
}

// ============================================
// TAX RATES
// ============================================

enum TaxRateType {
  VAT
  EXCISE
  WHT
}

model TaxRate {
  id          String      @id @default(uuid())
  name        String
  rate        Decimal     @db.Decimal(5, 4)
  type        TaxRateType
  isDefault   Boolean     @default(false)
  glAccountId String?
  glAccount   Account?    @relation(fields: [glAccountId], references: [id])
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("tax_rates")
}

model TaxGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  taxRateIds  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tax_groups")
}

// ============================================
// CONTACTS
// ============================================

enum ContactType {
  COMPANY
  INDIVIDUAL
}

enum LeadStage {
  NEW
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum LeadActivityType {
  CALL
  EMAIL
  MEETING
  FOLLOW_UP
  NOTE
}

enum ApprovalEntityType {
  SALES_INVOICE
  PURCHASE_ORDER
  PAYROLL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CONSUMED
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model Contact {
  id           String      @id @default(uuid())
  type         ContactType @default(INDIVIDUAL)
  name         String
  companyId    String?
  company      Contact?    @relation("CompanyContacts", fields: [companyId], references: [id])
  contacts     Contact[]   @relation("CompanyContacts")
  email        String?
  phone        String?
  mobile       String?
  website      String?
  street       String?
  street2      String?
  city         String?
  state        String?
  zip          String?
  country      String?
  taxId        String?
  jobPosition  String?
  partnerLevel String?
  tags         String[]
  notes        String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("contacts")
}

model CrmLead {
  id                String            @id @default(uuid())
  title             String
  companyName       String?
  contactName       String?
  email             String?
  phone             String?
  estimatedValue    Decimal?          @db.Decimal(18, 2)
  stage             LeadStage         @default(NEW)
  probability       Int               @default(0)
  expectedCloseDate DateTime?
  source            String?
  notes             String?
  createdById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  activities        CrmLeadActivity[]

  @@map("crm_leads")
}

model CrmLeadActivity {
  id          String           @id @default(uuid())
  leadId       String
  lead         CrmLead          @relation(fields: [leadId], references: [id])
  type         LeadActivityType
  summary      String
  dueDate      DateTime?
  completedAt  DateTime?
  createdById  String?
  createdAt    DateTime         @default(now())

  @@map("crm_lead_activities")
}

model ApprovalRequest {
  id             String             @id @default(uuid())
  entityType     ApprovalEntityType
  entityId       String
  status         ApprovalStatus     @default(PENDING)
  assignedRole   Role?
  amountSnapshot Decimal?           @db.Decimal(18, 2)
  requestedById  String?
  approvedById   String?
  rejectedById   String?
  comments       String?
  rejectionReason String?
  dueAt          DateTime?
  escalationCount Int               @default(0)
  lastEscalatedAt DateTime?
  requestedAt    DateTime           @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  consumedAt     DateTime?

  @@index([entityType, entityId, status])
  @@index([status, dueAt])
  @@map("approval_requests")
}

// ============================================
// SALES QUOTES, CREDIT NOTES, PRICE LISTS
// ============================================

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum CreditNoteStatus {
  DRAFT
  APPROVED
  APPLIED
}

model SalesQuote {
  id          String           @id @default(uuid())
  quoteNumber String           @unique
  customerId  String
  customer    Customer         @relation(fields: [customerId], references: [id])
  invoiceId   String?
  invoice     SalesInvoice?    @relation(fields: [invoiceId], references: [id])
  status      QuoteStatus      @default(DRAFT)
  validUntil  DateTime?
  subtotal    Decimal          @db.Decimal(18, 2)
  taxAmount   Decimal          @db.Decimal(18, 2)
  total       Decimal          @db.Decimal(18, 2)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       SalesQuoteItem[]

  @@map("sales_quotes")
}

model SalesQuoteItem {
  id          String     @id @default(uuid())
  quoteId     String
  quote       SalesQuote @relation(fields: [quoteId], references: [id])
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  description String?
  quantity    Decimal    @db.Decimal(18, 2)
  unitPrice   Decimal    @db.Decimal(18, 2)
  discount    Decimal    @default(0) @db.Decimal(5, 2)
  taxRate     Decimal    @db.Decimal(5, 2)
  taxAmount   Decimal    @db.Decimal(18, 2)
  lineTotal   Decimal    @db.Decimal(18, 2)
  createdAt   DateTime   @default(now())

  @@map("sales_quote_items")
}

model CreditNote {
  id               String           @id @default(uuid())
  creditNoteNumber String           @unique
  customerId       String
  customer         Customer         @relation(fields: [customerId], references: [id])
  invoiceId        String?
  invoice          SalesInvoice?    @relation(fields: [invoiceId], references: [id])
  reason           String?
  status           CreditNoteStatus @default(DRAFT)
  subtotal         Decimal          @db.Decimal(18, 2)
  taxAmount        Decimal          @db.Decimal(18, 2)
  total            Decimal          @db.Decimal(18, 2)
  approvedAt       DateTime?
  appliedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  items            CreditNoteItem[]

  @@map("credit_notes")
}

model CreditNoteItem {
  id           String     @id @default(uuid())
  creditNoteId String
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  description  String?
  quantity     Decimal    @db.Decimal(18, 2)
  unitPrice    Decimal    @db.Decimal(18, 2)
  taxRate      Decimal    @db.Decimal(5, 2)
  taxAmount    Decimal    @db.Decimal(18, 2)
  lineTotal    Decimal    @db.Decimal(18, 2)
  createdAt    DateTime   @default(now())

  @@map("credit_note_items")
}

model PriceList {
  id        String          @id @default(uuid())
  name      String
  currency  String          @default("KES")
  validFrom DateTime?
  validTo   DateTime?
  isDefault Boolean         @default(false)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     PriceListItem[]

  @@map("price_lists")
}

model PriceListItem {
  id          String    @id @default(uuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  price       Decimal   @db.Decimal(18, 2)
  minQty      Decimal   @default(1) @db.Decimal(18, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([priceListId, productId, minQty])
  @@map("price_list_items")
}

// ============================================
// INVENTORY — LOTS, SERIALS, TRANSFERS, COUNTS
// ============================================

enum SerialStatus {
  IN_STOCK
  SOLD
  RETURNED
}

enum LandedCostMethod {
  EQUAL
  BY_QTY
  BY_VALUE
}

enum LandedCostStatus {
  DRAFT
  APPLIED
}

enum StockCountStatus {
  DRAFT
  IN_PROGRESS
  VALIDATED
}

enum TransferStatus {
  DRAFT
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model Lot {
  id              String          @id @default(uuid())
  lotNumber       String          @unique
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  expiryDate      DateTime?
  manufactureDate DateTime?
  quantity        Decimal         @default(0) @db.Decimal(18, 2)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  stockMovements  StockMovement[]

  @@map("lots")
}

model SerialNumber {
  id            String       @id @default(uuid())
  serial        String       @unique
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  warehouseId   String?
  warehouse     Warehouse?   @relation(fields: [warehouseId], references: [id])
  status        SerialStatus @default(IN_STOCK)
  soldInvoiceId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("serial_numbers")
}

model LandedCost {
  id              String           @id @default(uuid())
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  description     String?
  amount          Decimal          @db.Decimal(18, 2)
  method          LandedCostMethod @default(BY_VALUE)
  status          LandedCostStatus @default(DRAFT)
  appliedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           LandedCostItem[]

  @@map("landed_costs")
}

model LandedCostItem {
  id              String     @id @default(uuid())
  landedCostId    String
  landedCost      LandedCost @relation(fields: [landedCostId], references: [id])
  productId       String
  product         Product    @relation(fields: [productId], references: [id])
  allocatedAmount Decimal    @db.Decimal(18, 2)
  createdAt       DateTime   @default(now())

  @@map("landed_cost_items")
}

model StockCount {
  id          String           @id @default(uuid())
  reference   String           @unique
  warehouseId String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  status      StockCountStatus @default(DRAFT)
  countDate   DateTime
  notes       String?
  validatedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lines       StockCountLine[]

  @@map("stock_counts")
}

model StockCountLine {
  id           String     @id @default(uuid())
  stockCountId String
  stockCount   StockCount @relation(fields: [stockCountId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  expectedQty  Decimal    @db.Decimal(18, 2)
  countedQty   Decimal    @default(0) @db.Decimal(18, 2)
  difference   Decimal    @default(0) @db.Decimal(18, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("stock_count_lines")
}

model RecurringInvoiceTemplate {
  id                   String                        @id @default(uuid())
  name                 String
  customerId           String
  customer             Customer                      @relation(fields: [customerId], references: [id])
  branchId             String?
  branch               Branch?                       @relation(fields: [branchId], references: [id])
  frequency            RecurringFrequency            @default(MONTHLY)
  startDate            DateTime
  nextRunDate          DateTime
  endDate              DateTime?
  isActive             Boolean                       @default(true)
  autoApprove          Boolean                       @default(false)
  defaultPaymentMethod PaymentMethod?
  notes                String?
  createdById          String?
  lastRunAt            DateTime?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  items                RecurringInvoiceTemplateItem[]
  runs                 RecurringInvoiceRun[]

  @@index([nextRunDate, isActive])
  @@map("recurring_invoice_templates")
}

model RecurringInvoiceTemplateItem {
  id          String                   @id @default(uuid())
  templateId  String
  template    RecurringInvoiceTemplate @relation(fields: [templateId], references: [id])
  productId   String
  product     Product                  @relation(fields: [productId], references: [id])
  description String?
  quantity    Decimal                  @db.Decimal(18, 2)
  unitPrice   Decimal                  @db.Decimal(18, 2)
  taxRate     Decimal                  @db.Decimal(5, 2)
  createdAt   DateTime                 @default(now())

  @@map("recurring_invoice_template_items")
}

model RecurringInvoiceRun {
  id           String                   @id @default(uuid())
  templateId   String
  template     RecurringInvoiceTemplate @relation(fields: [templateId], references: [id])
  runDate      DateTime
  invoiceId    String?
  invoice      SalesInvoice?            @relation(fields: [invoiceId], references: [id])
  status       String
  errorMessage String?
  createdAt    DateTime                 @default(now())

  @@map("recurring_invoice_runs")
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  sku       String   @unique
  attributes Json
  price     Decimal? @db.Decimal(18, 2)
  stockQty  Decimal  @default(0) @db.Decimal(18, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_variants")
}

model StockTransfer {
  id              String              @id @default(uuid())
  reference       String              @unique
  fromWarehouseId String
  fromWarehouse   Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  status          TransferStatus      @default(DRAFT)
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lines           StockTransferLine[]

  @@map("stock_transfers")
}

model StockTransferLine {
  id              String        @id @default(uuid())
  stockTransferId String
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(18, 2)
  createdAt       DateTime      @default(now())

  @@map("stock_transfer_lines")
}

// ============================================
// PROCUREMENT — RFQ, VENDOR BILLS, RETURNS
// ============================================

enum RFQStatus {
  DRAFT
  SENT
  RECEIVED
  CONVERTED
  CANCELLED
}

enum VendorBillStatus {
  DRAFT
  APPROVED
  PAID
  VOID
}

enum PurchaseReturnStatus {
  DRAFT
  APPROVED
}

model RequestForQuotation {
  id              String         @id @default(uuid())
  rfqNumber       String         @unique
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  status          RFQStatus      @default(DRAFT)
  requestDate     DateTime
  vendorReference String?
  paymentTerms    String?
  orderDeadline   DateTime?
  expectedArrival DateTime?
  deliverTo       String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           RFQItem[]
  purchaseOrder   PurchaseOrder?

  @@map("requests_for_quotation")
}

model RFQItem {
  id            String              @id @default(uuid())
  rfqId         String
  rfq           RequestForQuotation @relation(fields: [rfqId], references: [id])
  productId     String
  product       Product             @relation(fields: [productId], references: [id])
  quantity      Decimal             @db.Decimal(18, 2)
  expectedPrice Decimal?            @db.Decimal(18, 2)
  quotedPrice   Decimal?            @db.Decimal(18, 2)
  taxRate       Decimal             @default(0.16) @db.Decimal(5, 2)
  taxAmount     Decimal             @default(0) @db.Decimal(18, 2)
  lineTotal     Decimal             @default(0) @db.Decimal(18, 2)
  createdAt     DateTime            @default(now())

  @@map("rfq_items")
}

model VendorBill {
  id              String           @id @default(uuid())
  billNumber      String           @unique
  supplierId      String
  supplier        Supplier         @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  billDate        DateTime
  dueDate         DateTime?
  status          VendorBillStatus @default(DRAFT)
  subtotal        Decimal          @db.Decimal(18, 2)
  taxAmount       Decimal          @db.Decimal(18, 2)
  total           Decimal          @db.Decimal(18, 2)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           VendorBillItem[]

  @@map("vendor_bills")
}

model VendorBillItem {
  id           String     @id @default(uuid())
  vendorBillId String
  vendorBill   VendorBill @relation(fields: [vendorBillId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  description  String?
  quantity     Decimal    @db.Decimal(18, 2)
  unitCost     Decimal    @db.Decimal(18, 2)
  taxRate      Decimal    @db.Decimal(5, 2)
  taxAmount    Decimal    @db.Decimal(18, 2)
  lineTotal    Decimal    @db.Decimal(18, 2)
  createdAt    DateTime   @default(now())

  @@map("vendor_bill_items")
}

model PurchaseReturn {
  id              String               @id @default(uuid())
  returnNumber    String               @unique
  supplierId      String
  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  reason          String?
  status          PurchaseReturnStatus @default(DRAFT)
  total           Decimal              @db.Decimal(18, 2)
  approvedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  items           PurchaseReturnItem[]

  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  quantity         Decimal        @db.Decimal(18, 2)
  unitCost         Decimal        @db.Decimal(18, 2)
  lineTotal        Decimal        @db.Decimal(18, 2)
  createdAt        DateTime       @default(now())

  @@map("purchase_return_items")
}

// ============================================
// HR — ATTENDANCE, RECRUITMENT, APPRAISALS
// ============================================

enum AttendanceType {
  REGULAR
  OVERTIME
}

enum JobPostingStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  RECEIVED
  SHORTLISTED
  INTERVIEWED
  OFFERED
  HIRED
  REJECTED
}

enum InterviewResult {
  PENDING
  PASS
  FAIL
}

enum AppraisalStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum AllowanceType {
  HOUSING
  TRANSPORT
  MEDICAL
  OTHER
}

model AttendanceRecord {
  id           String         @id @default(uuid())
  employeeId   String
  employee     Employee       @relation(fields: [employeeId], references: [id])
  clockIn      DateTime
  clockOut     DateTime?
  durationMins Int?
  type         AttendanceType @default(REGULAR)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("attendance_records")
}

model JobPosting {
  id           String           @id @default(uuid())
  title        String
  department   String?
  description  String?
  requirements String?
  status       JobPostingStatus @default(OPEN)
  closingDate  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]

  @@map("job_postings")
}

model JobApplication {
  id            String            @id @default(uuid())
  jobPostingId  String
  jobPosting    JobPosting        @relation(fields: [jobPostingId], references: [id])
  applicantName String
  email         String
  phone         String?
  cvUrl         String?
  coverLetter   String?
  status        ApplicationStatus @default(RECEIVED)
  hiredAs       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  interviews    Interview[]

  @@map("job_applications")
}

model Interview {
  id               String          @id @default(uuid())
  jobApplicationId String
  jobApplication   JobApplication  @relation(fields: [jobApplicationId], references: [id])
  scheduledAt      DateTime
  interviewerId    String
  location         String?
  notes            String?
  feedback         String?
  result           InterviewResult @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("interviews")
}

model Appraisal {
  id           String          @id @default(uuid())
  employeeId   String
  employee     Employee        @relation(fields: [employeeId], references: [id])
  reviewerId   String
  period       String
  status       AppraisalStatus @default(DRAFT)
  overallScore Decimal?        @db.Decimal(4, 2)
  comments     String?
  submittedAt  DateTime?
  approvedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  items        AppraisalItem[]

  @@map("appraisals")
}

model AppraisalItem {
  id          String    @id @default(uuid())
  appraisalId String
  appraisal   Appraisal @relation(fields: [appraisalId], references: [id])
  criteria    String
  target      String?
  achievement String?
  score       Decimal?  @db.Decimal(4, 2)
  weight      Decimal   @default(1) @db.Decimal(4, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("appraisal_items")
}

model Allowance {
  id          String        @id @default(uuid())
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id])
  type        AllowanceType
  amount      Decimal       @db.Decimal(18, 2)
  isRecurring Boolean       @default(true)
  isActive    Boolean       @default(true)
  startDate   DateTime
  endDate     DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("allowances")
}

model LoanDeduction {
  id               String   @id @default(uuid())
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id])
  description      String?
  totalAmount      Decimal  @db.Decimal(18, 2)
  monthlyDeduction Decimal  @db.Decimal(18, 2)
  balance          Decimal  @db.Decimal(18, 2)
  startDate        DateTime
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("loan_deductions")
}

// ============================================
// REORDER RULES
// ============================================

model ReorderRule {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  preferredSupplierId String?
  preferredSupplier   Supplier? @relation(fields: [preferredSupplierId], references: [id])
  reorderPoint    Decimal  @db.Decimal(18, 2) // trigger when stock <= this
  reorderQty      Decimal  @db.Decimal(18, 2) // suggested qty to order
  maxStock        Decimal? @db.Decimal(18, 2) // optional max stock level
  isAutomatic     Boolean  @default(false) // auto-create PO suggestion
  isActive        Boolean  @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId])
  @@map("reorder_rules")
}

// ============================================
// BUDGET
// ============================================

enum BudgetStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model Budget {
  id          String       @id @default(uuid())
  name        String
  fiscalYear  Int
  startDate   DateTime
  endDate     DateTime
  status      BudgetStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lines       BudgetLine[]

  @@unique([fiscalYear, name])
  @@map("budgets")
}

model BudgetLine {
  id        String  @id @default(uuid())
  budgetId  String
  budget    Budget  @relation(fields: [budgetId], references: [id])
  accountId String
  account   Account @relation(fields: [accountId], references: [id])
  month     Int     // 1-12
  amount    Decimal @db.Decimal(18, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetId, accountId, month])
  @@map("budget_lines")
}

// ============================================
// MANUFACTURING (MRP)
// ============================================

enum BOMStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum WorkOrderStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
}

model BillOfMaterial {
  id          String    @id @default(uuid())
  name        String
  productId   String
  product     Product   @relation("BOMProduct", fields: [productId], references: [id])
  quantity    Decimal   @default(1) @db.Decimal(18, 2) // output qty per run
  status      BOMStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lines       BOMLine[]
  workOrders  WorkOrder[]

  @@map("bills_of_material")
}

model BOMLine {
  id          String          @id @default(uuid())
  bomId       String
  bom         BillOfMaterial  @relation(fields: [bomId], references: [id])
  productId   String
  product     Product         @relation("BOMComponent", fields: [productId], references: [id])
  quantity    Decimal         @db.Decimal(18, 2) // qty per 1 unit of finished product
  notes       String?
  createdAt   DateTime        @default(now())

  @@unique([bomId, productId])
  @@map("bom_lines")
}

model WorkOrder {
  id             String          @id @default(uuid())
  reference      String          @unique
  bomId          String
  bom            BillOfMaterial  @relation(fields: [bomId], references: [id])
  quantity       Decimal         @db.Decimal(18, 2) // how many units to produce
  status         WorkOrderStatus @default(DRAFT)
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  notes          String?
  createdById    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("work_orders")
}

// ============================================
// PLUGIN SYSTEM
// ============================================

enum PluginStatus {
  ACTIVE
  INACTIVE
  ERROR
}

model Plugin {
  id          String       @id @default(uuid())
  name        String       @unique
  version     String
  description String?
  author      String?
  entryPoint  String       // module path or class name
  config      Json?        // plugin-specific configuration
  status      PluginStatus @default(INACTIVE)
  installedAt DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("plugins")
}

// ============================================
// FEATURE FLAGS
// ============================================

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isEnabled   Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

